# NexusClaw — Environment Variables
# Copy to .env and fill in your values

# ─── Core ──────────────────────────────────────────────────────────────────────
NEXUSCLAW_PORT=19789
NODE_ENV=production

# ─── AI Providers ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
# OLLAMA_BASE_URL=http://192.168.178.90:11434

# ─── Channels ──────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ─── Image Generation ──────────────────────────────────────────────────────────
# ComfyUI on Greench machine
COMFYUI_BASE_URL=http://192.168.178.76:8188
# AUTOMATIC1111_BASE_URL=
# REPLICATE_API_KEY=

# ─── Gateway Auth ──────────────────────────────────────────────────────────────
# NEXUSCLAW_GATEWAY_PASSWORD=changeme
# NEXUSCLAW_GATEWAY_AUTH_MODE=password

# ─── Tailscale (optional) ──────────────────────────────────────────────────────
# NEXUSCLAW_TAILSCALE_MODE=off   # off | serve | funnel

# ─── Chrome Extension ──────────────────────────────────────────────────────────
NEXUSCLAW_CHROME_EXT_ALLOWED_ORIGINS=http://localhost:19789
