{
  "name": "nexusclaw",
  "version": "1.0.0",
  "description": "NexusClaw — AI agent framework. Your framework. Your rules.",
  "author": "Greench + Naruto",
  "license": "MIT",
  "repository": "https://github.com/greench-ai/nexusclaw",
  "keywords": ["ai", "agent", "framework", "llm", "claude", "evoclaw", "nexusclaw"],
  "scripts": {
    "start": "python apps/api/main.py",
    "web": "python apps/web/server.py",
    "setup": "python src/onboard/setup.py",
    "cli": "python src/cli/cli.py",
    "doctor": "python src/cli/cli.py doctor",
    "dev:api": "uvicorn apps.api.main:app --reload --port 8080",
    "dev:web": "python apps/web/server.py",
    "install-deps": "pip install -r requirements.txt",
    "docker:build": "docker build -t nexusclaw .",
    "docker:run": "docker-compose up -d"
  },
  "engines": {
    "node": ">=18",
    "python": ">=3.10"
  }
}
